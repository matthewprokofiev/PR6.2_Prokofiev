<Page x:Class="PR4.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Задание 2">
    <Grid Background="White">
        <StackPanel Margin="20" HorizontalAlignment="Left">
            <TextBlock Text="Задание 2: Условный расчет" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <Image Source="/images/formula2.png" Height="70" Margin="0,0,0,10" ToolTip="Расчет S в зависимости от x*b"/>

            <UniformGrid Columns="2" Width="250" HorizontalAlignment="Left">
                <Label Content="Переменная x:"/>
                <TextBox x:Name="txtX" Margin="5" ToolTip="Введите x"/>
                <Label Content="Переменная b:"/>
                <TextBox x:Name="txtB" Margin="5" ToolTip="Введите b"/>
            </UniformGrid>

            <GroupBox Header="Выберите f(x)" Margin="0,10,0,10" Width="250" HorizontalAlignment="Left">
                <StackPanel>
                    <RadioButton x:Name="rbSh" Content="sh(x)" IsChecked="True" ToolTip="Гиперболический синус"/>
                    <RadioButton x:Name="rbSq" Content="x²" ToolTip="Квадрат x"/>
                    <RadioButton x:Name="rbExp" Content="e^x" ToolTip="Экспонента"/>
                </StackPanel>
            </GroupBox>

            <Button Content="Вычислить" Width="100" HorizontalAlignment="Left" Margin="0,0,0,10" Click="Calc_Click"/>
            <Label Content="Результат s:"/>
            <TextBox x:Name="txtResult" Width="250" HorizontalAlignment="Left" IsReadOnly="True" Background="#F0F0F0"/>
        </StackPanel>
    </Grid>
</Page>