<Window x:Class="PR4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 6 часть 2" Height="600" Width="800"
        Closing="Window_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#EEE" Margin="10">
            <Button Content="Задание 1" Margin="5" Click="BtnPage1_Click" ToolTip="Перейти к первой формуле"/>
            <Button Content="Задание 2" Margin="5" Click="BtnPage2_Click" ToolTip="Перейти ко второй формуле"/>
            <Button Content="Задание 3" Margin="5" Click="BtnPage3_Click" ToolTip="Перейти к расчету цикла и графику"/>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>